# Python caches and local runtime files
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments are very large and should be recreated from requirements.
env_*/
.venv/
venv/

# Local editor and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db

# Licensed/reference PDFs are kept locally and cited by DOI in the paper.
journals/*.pdf

# Upstream repositories are cloned locally by QECO_DROO.py.
# Local experiment modifications are tracked as patch files under patches/.
DROO/
QECO/

# Raw run folders are regenerated by the experiment scripts.
# Keep comparison artifacts and formula figures because the paper references them.
experiment_results/*
!experiment_results/comparisons/
!experiment_results/comparisons/**
!experiment_results/formula_visualizations/
!experiment_results/formula_visualizations/**

# Large model/checkpoint artifacts, if generated later.
*.ckpt
*.h5
*.pb
*.pt
*.pth
checkpoints/
models/
